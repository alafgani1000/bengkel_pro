generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  name         String
  username     String        @unique
  passwordHash String
  role         String        // OWNER | ADMIN | MEKANIK | KASIR
  pin          String?       // 4-digit
  isActive     Boolean       @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  workOrders   WorkOrder[]   @relation("MekanikWorkOrders")
  stokMutasis  StokMutasi[]

  @@map("users")
}

model Bengkel {
  id               Int      @id @default(1) // Always 1
  nama             String
  alamat           String
  kota             String
  telepon          String
  email            String?
  logoPath         String?
  nomorRekening    String?
  namaBankRekening String?
  jamBuka          String
  jamTutup         String
  updatedAt        DateTime @updatedAt

  @@map("bengkel")
}

model Customer {
  id            String       @id @default(uuid())
  name          String
  phone         String       @unique
  email         String?
  address       String?
  loyaltyPoints Int          @default(0)
  totalVisits   Int          @default(0)
  referredById  String?
  referredBy    Customer?    @relation("Referrals", fields: [referredById], references: [id])
  referrals     Customer[]   @relation("Referrals")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  kendaraans    Kendaraan[]
  workOrders    WorkOrder[]
  invoices      Invoice[]
  reminders     Reminder[]

  @@map("customers")
  @@index([phone])
}

model Kendaraan {
  id             String       @id @default(uuid())
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  platNomor      String       @unique
  merek          String
  model          String
  tahun          String
  warna          String
  jenisKendaraan String       // MOBIL | MOTOR
  lastOdometerKm Int?
  catatanKhusus  String?
  createdAt      DateTime     @default(now())

  workOrders     WorkOrder[]
  reminders      Reminder[]

  @@map("kendaraans")
  @@index([platNomor])
}

model WorkOrder {
  id              String          @id @default(uuid())
  nomorSPK        String          @unique // SPK-YYYYMMDD-XXXX
  kendaraanId     String
  kendaraan       Kendaraan       @relation(fields: [kendaraanId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  mekanikId       String
  mekanik         User            @relation("MekanikWorkOrders", fields: [mekanikId], references: [id])
  status          String          // ANTRI | DIKERJAKAN | SELESAI | DIAMBIL | BATAL
  keluhan         String
  estimasiBiaya   Float           @default(0)
  totalBiaya      Float           @default(0)
  fotoMasukPaths  String          @default("[]") // JSON array
  fotoKeluarPaths String          @default("[]") // JSON array
  catatanMekanik  String?
  startedAt       DateTime?
  completedAt     DateTime?
  pickedUpAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items           WorkOrderItem[]
  invoice         Invoice?

  @@map("work_orders")
  @@index([nomorSPK])
}

model WorkOrderItem {
  id           String      @id @default(uuid())
  workOrderId  String
  workOrder    WorkOrder   @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  type         String      // JASA | SPAREPART
  nama         String
  qty          Int         @default(1)
  hargaSatuan  Float
  subtotal     Float
  sparepartId  String?
  sparepart    Sparepart?  @relation(fields: [sparepartId], references: [id])

  @@map("work_order_items")
}

model Sparepart {
  id           String          @id @default(uuid())
  kode         String          @unique
  nama         String
  merek        String?
  kategori     String
  stokSaatIni  Int             @default(0)
  stokMinimum  Int             @default(0)
  hargaBeli    Float           @default(0)
  hargaJual    Float           @default(0)
  satuan       String          // PCS | SET | LITER | METER
  lokasiRak    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  workItems    WorkOrderItem[]
  stokMutasis  StokMutasi[]

  @@map("spareparts")
  @@index([kode])
}

model Invoice {
  id             String      @id @default(uuid())
  nomorInvoice   String      @unique // INV-YYYYMMDD-XXXX
  workOrderId    String      @unique
  workOrder      WorkOrder   @relation(fields: [workOrderId], references: [id])
  customerId     String
  customer       Customer    @relation(fields: [customerId], references: [id])
  subtotal       Float
  diskon         Float       @default(0)
  pajak          Float       @default(0)
  total          Float
  status         String      // BELUM_BAYAR | LUNAS | SEBAGIAN
  metodeBayar    String?     // TUNAI | TRANSFER | QRIS | KARTU | CICILAN
  nominalDibayar Float       @default(0)
  kembalian      Float       @default(0)
  paidAt         DateTime?
  createdAt      DateTime    @default(now())

  @@map("invoices")
  @@index([nomorInvoice])
}

model StokMutasi {
  id           String     @id @default(uuid())
  sparepartId  String
  sparepart    Sparepart  @relation(fields: [sparepartId], references: [id], onDelete: Cascade)
  type         String     // MASUK | KELUAR | TRANSFER | ADJUSTMENT
  qty          Int
  qtyBefore    Int
  qtyAfter     Int
  keterangan   String
  referenceId  String?
  createdById  String
  createdBy    User       @relation(fields: [createdById], references: [id])
  createdAt    DateTime   @default(now())

  @@map("stok_mutasis")
}

model Reminder {
  id            String     @id @default(uuid())
  customerId    String
  customer      Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  kendaraanId   String
  kendaraan     Kendaraan  @relation(fields: [kendaraanId], references: [id], onDelete: Cascade)
  type          String     // SERVICE_BERKALA | GANTI_OLI | PAJAK_KENDARAAN
  tanggalTarget DateTime
  pesan         String
  isSent        Boolean    @default(false)
  sentAt        DateTime?
  isRead        Boolean    @default(false)
  createdAt     DateTime   @default(now())

  @@map("reminders")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model BackupLog {
  id           String   @id @default(uuid())
  filePath     String
  fileSize     Int
  isSuccess    Boolean
  errorMessage String?
  createdAt    DateTime @default(now())

  @@map("backup_logs")
}
